void UDF_Setup()
{
  auto mesh = nrs->scalar->mesh("temperature");

  // arbitrary arrays on the host where we will fill some initial data
  std::vector<dfloat> U(nrs->fluid->fieldOffsetSum, 0.0);
  std::vector<dfloat> P(mesh->Nlocal, 0.0);
  std::vector<dfloat> temp(mesh->Nlocal, 0.0);

  auto [x, y, z] = mesh->xyzHost();

  int n_gll_points = mesh->Np * mesh->Nelements;
  for (int n = 0; n < n_gll_points; ++n)
  {
    dfloat r = std::sqrt(x[n]*x[n] + y[n]*y[n] + z[n]*z[n]);

    U[n + 0 * nrs->fieldOffset] = exp(-r*r);     // x-velocity
    U[n + 1 * nrs->fieldOffset] = exp(-r*r);     // y-velocity
    U[n + 2 * nrs->fieldOffset] = exp(-r*r);      // z-velocity

    P[n] = exp(x[n]) + sin(y[n]) + x[n]*y[n]*z[n]; // pressure

    temp[n] = exp(x[n]) + sin(y[n]) + x[n]*y[n]*z[n]; // temperature
  }

  // copy host data into the device data
  nrs->fluid->o_U.copyFrom(U.data(), U.size());
  nrs->fluid->o_P.copyFrom(P.data(), P.size());
  nrs->scalar->o_solution("temperature").copyFrom(temp.data(), temp.size());
}

