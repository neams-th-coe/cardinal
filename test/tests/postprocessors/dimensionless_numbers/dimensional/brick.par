[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 1
  dt = 5.0e-4
  polynomialOrder = 7
  checkpointControl = steps
  checkpointInterval = 2
  scalars = temperature

[FLUID VELOCITY]
  viscosity = 2.37e-4
  density = 834.5
  residualTol = 1.0e-6
  boundaryTypeMap = inlet, outlet, wall

[FLUID PRESSURE]

[SCALAR TEMPERATURE]
  transportCoeff = 1001400
  diffusionCoeff = 2.34
  solver = none
