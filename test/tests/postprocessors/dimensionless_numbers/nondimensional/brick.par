[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 1
  dt = 5.0e-4
  polynomialOrder = 7
  checkpointControl = steps
  checkpointInterval = 2
  scalars = temperature

[FLUID VELOCITY]
  viscosity = -880.2742616033756
  density = 1.0
  residualTol = 1.0e-6
  boundaryTypeMap = inlet, outlet, wall

[FLUID PRESSURE]
  residualTol = 1.0e-5

[SCALAR TEMPERATURE]
  solver = none
