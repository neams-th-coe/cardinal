[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 1
  dt = 5.0e-4
  polynomialOrder = 5
  checkpointControl = steps
  checkpointInterval = 2

[MESH]
  file=../nek_weighted_side_integral/brick.re2

[FLUID VELOCITY]
  solver = none
  viscosity = 20

[FLUID PRESSURE]

[SCALAR TEMPERATURE]
  solver = none
