[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 1
  dt = 5.0e-4
  polynomialOrder = 3
  checkpointControl = steps
  checkpointInterval = 2
  scalars = temperature, one, two, three

[MESH]
  file = ../../common_inputs/brick2.re2

[FLUID VELOCITY]
  solver = none

[FLUID PRESSURE]

[SCALAR TEMPERATURE]
  solver = none

[SCALAR ONE]
  solver = none

[SCALAR TWO]
  solver = none

[SCALAR THREE]
  solver = none

