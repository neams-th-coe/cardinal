[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 1
  dt = 5.0e-4
  polynomialOrder = 1
  writeControl = steps
  checkpointInterval = 2

[FLUID VELOCITY]
  solver = none

[FLUID PRESSURE]

[SCALAR TEMPERATURE]
  solver = none

[SCALAR01]
  solver = none

[SCALAR02]
  solver = none

[SCALAR03]
  solver = none

