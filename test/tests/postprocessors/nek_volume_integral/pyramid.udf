{
}

void UDF_Setup()
{
  auto mesh = nrs->scalar->mesh("temperature");

  // arbitrary arrays on the host where we will fill some initial data
  std::vector<dfloat> U(nrs->fluid->fieldOffsetSum, 0.0);
  std::vector<dfloat> temp(mesh->Nlocal, 0.0);
  std::vector<dfloat> one(mesh->Nlocal, 0.0);
  std::vector<dfloat> two(mesh->Nlocal, 0.0);
  std::vector<dfloat> three(mesh->Nlocal, 0.0);
  std::vector<dfloat> P(mesh->Nlocal, 0.0);

  auto [x, y, z] = mesh->xyzHost();

  for (int n = 0; n < mesh->Nlocal; ++n)
  {
    U[n + 0 * nrs->fieldOffset] = sin(x[n]);     // x-velocity
    U[n + 1 * nrs->fieldOffset] = y[n] + 1;      // y-velocity
    U[n + 2 * nrs->fieldOffset] = exp(x[n]*y[n]*z[n]); // z-velocity

    P[n] = exp(x[n]) + exp(y[n]) + exp(z[n]); // pressure

    temp[n] = exp(x[n]) + sin(y[n]) + x[n]*y[n]*z[n]; // temperature
    one[n] = exp(x[n]) + sin(y[n]) + x[n]*y[n]*z[n] + 1; // scalar 01
    two[n] = exp(x[n]) + sin(y[n]) + x[n]*y[n]*z[n] + 2; // scalar 02
    three[n] = exp(x[n]) + sin(y[n]) + x[n]*y[n]*z[n] + 3; // scalar 03
  }

  // copy host data into the device data
  nrs->fluid->o_U.copyFrom(U.data(), U.size());
  nrs->fluid->o_P.copyFrom(P.data(), P.size());
  nrs->scalar->o_solution("temperature").copyFrom(temp.data(), temp.size());
  nrs->scalar->o_solution("one").copyFrom(one.data(), one.size());
  nrs->scalar->o_solution("two").copyFrom(two.data(), two.size());
  nrs->scalar->o_solution("three").copyFrom(three.data(), three.size());
}

