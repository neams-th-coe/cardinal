[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 1
  dt = 5.0e-4
  polynomialOrder = 1
  checkpointControl = steps
  checkpointInterval = 2
  scalars = one, two, three

[MESH]
  file = "pyramid.re2"

[FLUID VELOCITY]
  solver = none

[FLUID PRESSURE]

[SCALAR ONE]
  solver = none

[SCALAR TWO]
  solver = none

[SCALAR THREE]
  solver = none

