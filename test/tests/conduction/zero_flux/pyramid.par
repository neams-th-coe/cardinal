[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 2
  dt = 1.0
  polynomialOrder = 5
  checkpointControl = steps
  checkpointInterval = 1
  scalars = temperature

[FLUID VELOCITY]
  solver = none    # fluid must be solved to read in bIDs

[FLUID PRESSURE]

[SCALAR TEMPERATURE]
  solver = none
