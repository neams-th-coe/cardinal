#ifdef __okl__

#include "pyramid.oudf"

#endif


void userq(double time)
{
  auto mesh = nrs->meshV;
  mooseHeatSource(mesh->Nelements, nrs->fieldOffset, platform->app->bc->o_usrwrk, nrs->scalar->o_EXT);
}

void UDF_Setup()
{
  nrs->userSource = &userq;
  auto mesh = nrs->meshV;

  std::vector<dfloat> temp(mesh->Nlocal, 500.0);
  nrs->scalar->o_solution("temperature").copyFrom(temp.data(), temp.size());
}

void UDF_ExecuteStep(double time, int tstep)
{
}
