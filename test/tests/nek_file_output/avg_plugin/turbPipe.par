[OCCA]
  backend = CPU

[GENERAL]
  polynomialOrder = 3
  stopAt = endTime
  endTime = 0.03

  dt = 6.0e-3
  timeStepper = tombo2

  checkpointControl = steps
  checkpointInterval = 3

  regularization = hpfrt + nModes=1 + scalingCoeff=0.1/${dt}

[FLUID PRESSURE]
  residualTol = 1e-04

[MESH]
  file=../../cht/sfr_pincell/sfr_pin.re2

[FLUID VELOCITY]
  boundaryTypeMap = wall, wall, inlet, outlet
  density = 1.0
  viscosity = -19000
  residualTol = 1e-06
  solver = none
