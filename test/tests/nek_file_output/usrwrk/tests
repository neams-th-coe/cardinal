[Tests]
  design = 'NekRSProblem.md'

  [check_scratch]
    type = CheckFiles
    input = nek.i
    check_files = 'aaa0.f00000 aaa0.f00001 aaa0.f00002 ccc0.f00000 ccc0.f00001 ccc0.f00002'
    min_slots = 2 # memory heavy
    requirement = "The system shall allow the user to write the user scratch space slots to field files."
    capabilities = 'nekrs'
  []
  [read1]
    type = CSVDiff
    input = read.i
    cli_args = 'Outputs/file_base=read1_out'
    csvdiff = read1_out.csv
    prereq = check_scratch
    working_directory = 'read'
    min_slots = 2 # memory heavy
    requirement = "The system shall write the correct usrwrk data into the scratch space. This is tested "
                  "by reading the written aaa0.f00001 file into a new simulation and applying it to the scalars, such "
                  "that various Cardinal postprocessors can read those values and confirm a match. This test "
                  "checks that the scalar indices are correctly interpreted when a temperature scalar is "
                  "present (the test does not work if temperature is present because NekRS tries to load "
                  "the restart file into the 0th scalar, which is temperature."
    capabilities = 'nekrs'
  []
  [read2]
    type = CSVDiff
    input = read.i
    cli_args = 'Problem/casename="read2" Outputs/file_base=read2_out'
    csvdiff = read2_out.csv
    prereq = check_scratch
    working_directory = 'read'
    min_slots = 2 # memory heavy
    requirement = "The system shall write the correct usrwrk data into the scratch space. This is tested "
                  "by reading the written ccc0.f00001 file into a new simulation and applying it to the scalars, such "
                  "that various Cardinal postprocessors can read those values and confirm a match. This test "
                  "checks that the scalar indices are correctly interpreted when a temperature scalar is "
                  "present (the test does not work if temperature is present because NekRS tries to load "
                  "the restart file into the 0th scalar, which is temperature."
    capabilities = 'nekrs'
  []
[]
