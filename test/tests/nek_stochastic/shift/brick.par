[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 3
  dt = 5.0e-1
  polynomialOrder = 3
  checkpointControl = steps
  checkpointInterval = 2
  scalars = temperature, 01, 02, 03

[MESH]
  file = ../../common_inputs/brick2.re2

[FLUID VELOCITY]
  solver = none

[FLUID PRESSURE]
  residualTol = 1.0e-5

[SCALAR TEMPERATURE]
  solver = none

[SCALAR 01]
  boundaryTypeMap = t, t, t, t, t, f
  residualTol = 1e-6
  diffusionCoeff = 1000.0

[SCALAR 02]
  solver = none

[SCALAR 03]
  solver = none
