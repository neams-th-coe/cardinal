[GENERAL]
polynomialOrder = 5
stopAt = numSteps
numSteps = 5
dt = 2e-03
timeStepper = tombo3
checkpointControl = steps
checkpointInterval = 5
scalars = temperature, one, two

[FLUID PRESSURE]

[FLUID VELOCITY]
solver = none

[SCALAR TEMPERATURE]
solver = none

[SCALAR ONE]
solver = none

[SCALAR TWO]
solver = none
