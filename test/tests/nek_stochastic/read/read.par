  file="../ethier.re2"

[FLUID PRESSURE]
  residualTol = 1e-08

[FLUID VELOCITY]
  solver = none

[SCALAR TEMPERATURE]
  solver = none

[SCALAR01]
  solver = none

[SCALAR02]
  solver = none
