[GENERAL]
  startFrom = ../a02ethier0.f00000
  polynomialOrder = 5
  stopAt = numSteps
  numSteps = 1
  dt = 2e-03
  timeStepper = tombo3
  checkpointControl = steps
  checkpointInterval = 5
  udf = "read.udf"
  scalars = temperature, one, two

[MESH]
  file="../ethier.re2"

[FLUID PRESSURE]
  residualTol = 1e-08

[FLUID VELOCITY]
  solver = none

[SCALAR TEMPERATURE]
  solver = none

[SCALAR ONE]
  solver = none

[SCALAR TWO]
  solver = none
