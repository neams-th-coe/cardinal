#ifdef __okl__

@kernel void cFillKernel(const dlong Nelements, const dlong offset, @restrict dfloat * value, @restrict dfloat * source)
{
  for(dlong e=0;e<Nelements;++e;@outer(0)){
    for(int n=0;n<p_Np;++n;@inner(0)){
      const int id = e*p_Np + n;
      source[offset + id] = value[0];
    }
  }
}

#endif

void UDF_LoadKernels(deviceKernelProperties &kernelInfo)
{
}

void UDF_Setup()
{
}

void UDF_ExecuteStep(double time, int tstep)
{
  mesh_t *mesh = nrs->meshV;

  auto usrwrk = platform->app->bc->o_usrwrk;

  // set scalar1 value to the 3rd slot (zero-indexed)
  cFillKernel(mesh->Nelements, 2 * nrs->fieldOffset, usrwrk, nrs->scalar->o_S);
}
