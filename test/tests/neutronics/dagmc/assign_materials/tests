[Tests]
  issues = '#1359'
  design = 'MoabSkinner.md OpenMCCellAverageProblem.md'
  [material_names_wrong_length]
    type = RunException
    input = generate_dagmc.i
    cli_args = "UserObjects/moab/material_names='1'"
    expect_err = "'material_names' \(length 1\) must be the same length as 'material_blocks' \(length 2\)"
    mesh_mode = 'replicated'
    capabilities = 'dagmc'
    requirement = "The system shall error if 'material_names' and 'material_blocks' are not the same length"
  []
  [material_blocks_not_in_mesh]
    type = RunException
    input = generate_dagmc.i
    cli_args = "UserObjects/moab/material_blocks='block_1 nonexistent'"
    expect_err = "Subdomain 'nonexistent' not found in the mesh"
    mesh_mode = 'replicated'
    capabilities = 'dagmc'
    requirement = "The system shall error if a block listed in 'material_blocks' does not exist in the mesh"
  []
  [material_blocks_duplicate]
    type = RunException
    input = generate_dagmc.i
    cli_args = "UserObjects/moab/material_blocks='1 block_1' UserObjects/moab/material_names='1 2'"
    expect_err = "Subdomain 'block_1' was already listed in 'material_blocks' \(either by name or ID\). Each block can only be listed one time."
    mesh_mode = 'replicated'
    capabilities = 'dagmc'
    requirement = "The system shall error if the same subdomain is listed more than once in 'material_blocks'"
  []
  [material_names_required_with_blocks]
    type = RunException
    input = no_material_names.i
    cli_args = "UserObjects/moab/material_blocks='block_1 block_2'"
    expect_err = "'material_names' parameter must be provided whenever 'material_blocks' is provided"
    mesh_mode = 'replicated'
    capabilities = 'dagmc'
    requirement = "The system shall error if 'material_blocks' is specified without 'material_names'"
  []
  [unlisted_block_void_warning]
    type = RunException
    input = generate_dagmc.i
    cli_args = "UserObjects/moab/material_blocks='block_1' UserObjects/moab/material_names='1' --error"
    expect_err = "The following mesh subdomains have no material assignment in MoabSkinner"
    mesh_mode = 'replicated'
    capabilities = 'dagmc'
    requirement = "The system shall warn when a mesh subdomain has no material assignment and will default to void"
  []
  [generate_dagmc]
    type = RunApp
    input = generate_dagmc.i
    mesh_mode = 'replicated'
    capabilities = 'dagmc'
    requirement = "The system shall assign materials to MOOSE mesh blocks and generate a new DAGMC geometry"
                  "with the correct material group tags"
  []
  [run_updated_geometry]
    type = CSVDiff
    prereq = generate_dagmc
    input = openmc.i
    csvdiff = openmc_out.csv
    requirement = "The system shall update material assignments with 'material_blocks' and 'material_names' "
                  "(using names or IDs) and run OpenMC with the regenerated geometry"
    mesh_mode = 'replicated'
    capabilities = 'dagmc'
  []
  [run_updated_geometry_with_void]
    type = CSVDiff
    prereq = generate_dagmc
    input = openmc.i
    csvdiff = void.csv
    cli_args = "UserObjects/moab/material_blocks='block_1' UserObjects/moab/material_names='2' Outputs/file_base='void'"
    requirement = "The system shall partially update material assignments with 'material_blocks' and 'material_names' "
                  "(using names or IDs) and assign void to missing block and run OpenMC with the regenerated geometry"
    mesh_mode = 'replicated'
    capabilities = 'dagmc'
  []
[]
