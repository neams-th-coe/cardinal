[Tests]
  # This test needs to be in its own directory to prevent a false positive if another test
  # writes a statepoint.50.h5 file
  [check_statepoint_exists]
    type = CheckFiles
    input = openmc.i
    issues = '#1312'
    design = 'OpenMCCellAverageProblem.md'
    check_files = 'statepoint_folder_ts_1/statepoint.50.h5 statepoint_folder_ts_2/statepoint.50.h5'
    # This test has very few particles, and OpenMC will error if there aren't enough source particles
    # in the fission bank on a process
    max_parallel = 8
    requirement = "A statepoint file must be written for each timestep into the correct directory when the batches parameter matches the batches "
                  "in settings.xml and they are both specified."
    capabilities = 'openmc'
  []

  [check_statepoint_exists_custom_dir]
    type = CheckFiles
    input = openmc_user_dir.i
    issues = '#1312'
    design = 'OpenMCCellAverageProblem.md'
    check_files = 'mystatepoints_ts_1/statepoint.50.h5 mystatepoints_ts_2/statepoint.50.h5'
    # This test has very few particles, and OpenMC will error if there aren't enough source particles
    # in the fission bank on a process
    max_parallel = 8
    requirement = "A statepoint file must be written for each timestep into the correct user defined directory."
    capabilities = 'openmc'
  []
[]
