[Tests]
  issues = '#1273'
  design = 'OpenMCCellAverageProblem.md'

  [density_feedback]
    type = CSVDiff
    input = openmc.i
    csvdiff = openmc_out.csv
    requirement = "The system shall support density feedback to OpenMC's random ray solver for the "
                  "case when only density feedback blocks are provided. This "
                  "test was verified with a standalone OpenMC simulation where distributed cell "
                  "densities were set in the Python API. The k-eff and standard deviations matched "
                  "exactly."
    capabilities = 'openmc'
  []
  [density_feedback_two_var]
    type = CSVDiff
    input = two_vars.i
    csvdiff = two_vars_out.csv
    requirement = "The system shall support density feedback to OpenMC's random ray solver for the "
                  "case when only density feedback blocks and variables are provided. This "
                  "test was verified with a standalone OpenMC simulation where distributed cell "
                  "densities were set in the Python API. The k-eff and standard deviations matched "
                  "exactly."
    capabilities = 'openmc'
  []
[]
