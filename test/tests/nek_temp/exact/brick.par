[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 2
  dt = 5.0e-4
  polynomialOrder = 3
  checkpointControl = steps
  checkpointInterval = 2
  scalars = temperature

[MESH]
  file = ../../common_inputs/brick2.re2

[FLUID VELOCITY]
  solver = none

[FLUID PRESSURE]

[SCALAR TEMPERATURE]
  solver = none
