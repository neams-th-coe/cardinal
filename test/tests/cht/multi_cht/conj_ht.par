[GENERAL]
  polynomialOrder = 1
  numSteps = 1
  dt = 2e-02
  timeStepper = tombo2
  checkpointInterval = 1

[FLUID VELOCITY]
  boundaryTypeMap = v, O, W, SYM
  residualTol = 1e-08
  solver = none

[FLUID PRESSURE]

[SCALAR TEMPERATURE]
  boundaryTypeMap = t, O, I, I
  residualTol = 1e-08
  solver = none

[SCALAR01]
  solver = none
