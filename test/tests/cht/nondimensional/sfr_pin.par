# Model of single SFR pincell, fluid region only. All units are nondimensional.
# The following reference scales are selected:
#
# L = 0.908e-2
# rho = 834.5
# Pr = 0.004532565021024762
# U = 0.000950466               inlet velocity from ../sfr_pincell
# T0 = 628.15                   inlet temperature from ../sfr_pincell
#
# The particular length scale selected is based on dividing the mesh in
# ../sfr_pincell by a factor of 0.908e-2 (the pin pitch)

[OCCA]
  backend = CPU

[GENERAL]
  numSteps = 2000
  dt = 0.10467687224669604
  checkpointInterval = 500
  polynomialOrder = 3
  scalars = temperature

[FLUID VELOCITY]
  # for constant properties, this is 1/Re. For non-constant properties, it is 1/Re * mu/mu_ref
  viscosity = -30.387881869873413
  density = 1.0
  boundaryTypeMap = zeroDirichlet, zeroDirichlet, udfDirichlet, zeroNeumann
  residualTol = 1.0e-7

[FLUID PRESSURE]
  residualTol = 1.0e-5

[SCALAR TEMPERATURE]
  # for constant properties, this is 1/Pe. For non-constant properties, it is 1/Pe * k/k_ref
  diffusionCoeff = -0.13773505042642078
  transportCoeff = 1.0
  boundaryTypeMap = udfNeumann, zeroNeumann, udfDirichlet, zeroNeumann
  residualTol = 1.0e-7
