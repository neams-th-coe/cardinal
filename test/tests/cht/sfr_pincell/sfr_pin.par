# Model of single SFR pincell, fluid region only. All units are in SI.
[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 4
  dt = 5e-3
  timeStepper = tombo2
  writeControl = steps
  checkpointInterval = 100
  polynomialOrder = 4

[PROBLEMTYPE]
  stressFormulation = true

[FLUID VELOCITY]
  viscosity = 2.37e-4
  density = 834.5
  boundaryTypeMap = W, W, v, O
  residualTol = 1.0e-6

[FLUID PRESSURE]
  residualTol = 1.0e-6

[SCALAR TEMPERATURE]
  conductivity = 64.21
  rhoCp = 1024766.0
  boundaryTypeMap = f, I, t, O
  residualTol = 1.0e-3
