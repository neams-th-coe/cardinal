[OCCA]
backend = CPU

[GENERAL]
polynomialOrder = 5
numSteps = 5
dt = 1e-04
checkpointInterval = 20
scalars = temperature

[MESH]
file = ../onepebble2.re2

[FLUID PRESSURE]
residualTol = 1e-06

[FLUID VELOCITY]
boundaryTypeMap = zeroDirichlet, zeroNeumann, udfDirichlet
residualTol = 1e-07
density = 1.0
viscosity = 0.00005

[SCALAR TEMPERATURE]
boundaryTypeMap = udfNeumann, zeroNeumann, udfDirichlet
transportCoeff = 100000.0
diffusionCoeff = 5.0
residualTol = 1e-07
