[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 1000
  dt = 5.0e-4
  polynomialOrder = 3
  checkpointControl = steps
  checkpointInterval = 2
  scalars = temperature

[MESH]
  file = ../used_scratch/brick.re2

[FLUID VELOCITY]
  solver = none

[FLUID PRESSURE]

[SCALAR TEMPERATURE]
  residualTol = 1e-6
  boundaryTypeMap = I, I, I, I, I, f
