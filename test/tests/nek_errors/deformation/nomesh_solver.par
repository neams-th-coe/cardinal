[GENERAL]
  polynomialOrder = 2
  stopAt = numSteps
  numSteps = 1
  dt = 1e-3
  timeStepper = tombo2
  checkpointInterval = 1
  oudf = "nekbox.oudf"
  udf = "nekbox.udf"
  scalars = temperature

[MESH]
  file = "nekbox.re2"

[GEOM]
  solver = none

[PROBLEMTYPE]
  stressFormulation = false

[FLUID PRESSURE]
  residualTol = 1e-4

[FLUID VELOCITY]
  solver = none

[SCALAR TEMPERATURE]
  solver = none
