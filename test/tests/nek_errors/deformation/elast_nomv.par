[GENERAL]
polynomialOrder = 2
stopAt = numSteps
numSteps = 1
dt = 1e-3
timeStepper = tombo2
checkpointInterval = 100
oudf = "nekbox_elast.oudf"
udf = "nekbox.udf"
scalars = temperature

[MESH]
file = "nekbox.re2"

[GEOM]
boundaryTypeMap = zeroDirichlet,zeroDirichlet,zeroDirichlet,zeroDirichlet,zeroDirichlet,zeroDirichlet
solver = pcg+block

[PROBLEMTYPE]
stressFormulation = true

[FLUID PRESSURE]
residualTol = 1e-4

[FLUID VELOCITY]
density = 1.0
viscosity = -100.0
boundaryTypeMap = zeroDirichlet,udfDirichlet,zeroDirichlet,zeroDirichlet,zeroDirichlet,zeroNeumann
residualTol = 1e-5

[SCALAR TEMPERATURE]
solver = none
