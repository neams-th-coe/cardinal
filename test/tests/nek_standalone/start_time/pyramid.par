[OCCA]
  backend = CPU

[GENERAL]
  startFrom = pyramid.fld
  stopAt = numSteps
  numSteps = 5
  dt = 5.0e-4
  polynomialOrder = 5
  writeControl = steps
  writeInterval = 2

[MESH]
  file = ../from_restart/pyramid.re2

[FLUID VELOCITY]
  solver = none

[FLUID PRESSURE]

[SCALAR TEMPERATURE]
  solver = none
