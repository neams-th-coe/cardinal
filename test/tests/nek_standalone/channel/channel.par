userSections = CASEDATA

[GENERAL]
  polynomialOrder = 7
  numSteps = 100
  dt = 1e-03
  timeStepper = tombo2
  checkpointInterval = 0

[PROBLEMTYPE]
  equation = Stokes+variableViscosity

[FLUID PRESSURE]
  residualTol = 1e-08

[FLUID VELOCITY]
  boundaryTypeMap = zeroDirichletN/zeroNeumann
  residualTol = 1e-12
  density = 1.0
  viscosity = 0.1

[CASEDATA]
  p_rot = 0.7853981633974483 # \pi / 4
