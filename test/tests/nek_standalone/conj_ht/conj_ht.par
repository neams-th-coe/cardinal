[GENERAL]
  polynomialOrder = 7
  numSteps = 5
  dt = 2e-02
  timeStepper = tombo2
  checkpointInterval = 100
  scalars = temperature

[FLUID PRESSURE]
  residualTol = 1e-06

[FLUID VELOCITY]
  boundaryTypeMap = udfDirichlet, zeroNeumann, zeroDirichlet
  residualTol = 1e-08
  density = 1.0
  viscosity = 0.001

[SCALAR TEMPERATURE]
  boundaryTypeMap = udfDirichlet, zeroNeumann, zeroNeumann
  residualTol = 1e-08
  transportCoeff = 1.0
  diffusionCoeff = 0.001
  mesh = fluid + solid
