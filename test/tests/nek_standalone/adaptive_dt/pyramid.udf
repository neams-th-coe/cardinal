void UDF_Setup()
{
  auto mesh = nrs->scalar->mesh("temperature");

  // This is only here to avoid a re-gold, because in a later version of NekRS
  // they changed the default time adaptivity scheme
  platform->options.setArgs("MAX ADJUST DT RATIO", "1.25"); // limit step size increase
  platform->options.setArgs("MIN ADJUST DT RATIO", "0");    // no-limit for step size reduction
}

