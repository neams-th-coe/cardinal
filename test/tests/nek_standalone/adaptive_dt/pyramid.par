[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 5
  polynomialOrder = 5
  writeControl = steps
  checkpointInterval = 5

  dt = targetCFL=0.4 + max=1e-2 + initial=1e-4

[MESH]
  file = ../from_restart/pyramid.re2

[FLUID VELOCITY]
  solver = none

[FLUID PRESSURE]

[SCALAR TEMPERATURE]
  solver = none
