      subroutine usrdat2()  ! This routine to modify mesh coordinates

      include 'SIZE'
      include 'TOTAL'

      call rescale_x(xm1, -0.0149182/7.646e-3, 0.0149182/7.646e-3)
      call rescale_x(ym1, -0.0129196/7.646e-3, 0.0129196/7.646e-3)
      call rescale_x(zm1, 0.0, 0.008/7.646e-3)

      return
      end
