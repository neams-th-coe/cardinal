}

void UDF_Setup()
{
  // set initial conditions for the velocity, temperature, and pressure. Because
  // we turn off the solves, we're just doing postprocessing of whatever we set
  // for the initial conditions
  mesh_t * mesh = nrs->scalar->mesh("temperature");

  // arbitrary arrays on the host where we will fill some initial data
  std::vector<dfloat> U(nrs->fluid->fieldOffsetSum, 0.0);
  std::vector<dfloat> P(mesh->Nlocal, 0.0);
  std::vector<dfloat> temp(mesh->Nlocal, 0.0);

  auto [x, y, z] = mesh->xyzHost();

  // loop over all the GLL points and assign directly to the solution arrays by
  // indexing according to the field offset necessary to hold the data for each
  // solution component
  for (int n = 0; n < mesh->Nlocal; ++n)
  {
    dfloat r = std::sqrt(x[n]*x[n] + y[n]*y[n]);

    dfloat theta;
    if (x[n] > 0 && y[n] >= 0)
      theta = std::atan(y[n] / x[n]);
    if (x[n] < 0 && y[n] >= 0)
      theta = M_PI - std::atan(std::abs(y[n] / x[n]));
    if (x[n] < 0 && y[n] < 0)
      theta = std::atan(y[n] / x[n]) + M_PI;
    if (x[n] > 0 && y[n] < 0)
      theta = 2 * M_PI - std::atan(std::abs(y[n] / x[n]));

    dfloat Vr = 0.0;
    dfloat Vt = 0.1 + 10.0 * r;
    U[n + 0 * nrs->fieldOffset] = Vr * std::cos(theta) - Vt * std::sin(theta);
    U[n + 1 * nrs->fieldOffset] = Vr * std::sin(theta) + Vt * std::cos(theta);
    U[n + 2 * nrs->fieldOffset] = 2.0;

    P[n] = x[n]+y[n]+z[n];

    temp[n] = exp(100*r)+200*z[n];
  }

  // copy host data into the device data
  nrs->fluid->o_U.copyFrom(U.data(), U.size());
  nrs->fluid->o_P.copyFrom(P.data(), P.size());
  nrs->scalar->o_solution("temperature").copyFrom(temp.data(), temp.size());
}

