[GENERAL]
  stopAt = numSteps
  numSteps = 1
  dt = 5.0e-4
  timeStepper = tombo2
  checkpointControl = steps
  checkpointInterval = 25
  dealiasing = yes
  polynomialOrder = 5
  scalars = temperature

[FLUID VELOCITY]
  solver = none

[FLUID PRESSURE]
  residualTol = 1.0e-6

[SCALAR TEMPERATURE]
  solver = none
