[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 2000
  dt = 0.2
  timeStepper = tombo2
  checkpointControl = steps
  checkpointInterval = 5
  polynomialOrder = 1
  scalars = temperature

[FLUID VELOCITY]
  solver = none

[FLUID PRESSURE]

[SCALAR TEMPERATURE]
  diffusionCoeff = 0.1
  transportCoeff = 1.0
  boundaryTypeMap = udfNeumann, udfDirichlet, zeroNeumann
  residualTol = 1.0e-6
