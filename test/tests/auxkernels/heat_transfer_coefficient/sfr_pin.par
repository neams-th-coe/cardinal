# Model of single SFR pincell, fluid region only. All units are in SI.
[OCCA]
  backend = CPU

[GENERAL]
  stopAt = numSteps
  numSteps = 100
  dt = 5e-3
  timeStepper = tombo2
  checkpointControl = steps
  checkpointInterval = 1000
  polynomialOrder = 1
  scalars = temperature

[MESH]
  file = ../../cht/sfr_pincell/sfr_pin.re2

[FLUID VELOCITY]
  viscosity = 2.37e-4
  density = 834.5
  boundaryTypeMap = zeroDirichlet, zeroDirichlet, udfDirichlet, zeroNeumann
  residualTol = 1.0e-6

[FLUID PRESSURE]
  residualTol = 1.0e-6

[SCALAR TEMPERATURE]
  diffusionCoeff = 64.21
  transportCoeff = 1024766.0
  boundaryTypeMap = udfNeumann, zeroNeumann, udfDirichlet, zeroNeumann
  residualTol = 1.0e-3
