void udfDirichlet(bcData *bc)
{
  if (isField("fluid velocity"))
  {
    bc->uxFluid = 0.0; // x-velocity
    bc->uyFluid = 0.0; // y-velocity
    bc->uzFluid = 1.0; // z-velocity
  }
  else if (isField("scalar temperature"))
    bc->sScalar = 0.0;
}

void udfNeumann(bcData * bc)
{
  bc->fluxScalar = 1.0; // heat flux
}
