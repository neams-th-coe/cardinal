[OCCA]
  backend = CPU

[GENERAL]
  polynomialOrder = 3
  numSteps = 10000
  dt = targetCFL=0.5 + initial=1e-4
  writeInterval = 1000
  scalars = temperature

[FLUID PRESSURE]
  residualTol = 1e-06

[FLUID VELOCITY]
  boundaryTypeMap = zeroDirichlet, udfDirichlet, zeroNeumann
  residualTol = 1e-07
  density = 1.0
  viscosity = -100

[SCALAR TEMPERATURE]
  boundaryTypeMap = udfNeumann, udfDirichlet, zeroNeumann
  residualTol = 1e-07
  transportCoeff = 1.0
  diffusionCoeff = -100
