[OCCA]
  backend = CPU

[GENERAL]
  polynomialOrder = 3
  numSteps = 10000
  dt = targetCFL=0.5 + initial=1e-4
  writeInterval = 100
  constFlowRate = meanVelocity=1.0 + direction=Z
  scalars = temperature

[FLUID PRESSURE]
  residualTol = 1e-06

[FLUID VELOCITY]
  boundaryTypeMap = zeroDirichlet
  residualTol = 1e-07
  density = 1.0
  viscosity = -100

[SCALAR TEMPERATURE]
  boundaryTypeMap = udfNeumann
  residualTol = 1e-07
  transportCoeff = 1.0
  diffusionCoeff = -100
