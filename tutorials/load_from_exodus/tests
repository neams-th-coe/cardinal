[Tests]
  [run_nek]
    type = RunApp
    input = nek.i
    requirement = "Cardinal shall be able to run NekRS and output a time history of its solution "
                  "onto a mesh mirror."
    capabilities = 'nekrs'
  []
  [load_nek]
    type = CSVDiff
    input = load_nek.i
    csvdiff = load_nek_out.csv
    prereq = run_nek
    requirement = "Cardinal shall be able to load a time history of a NekRS solution."
    capabilities = 'nekrs'
  []
[]
