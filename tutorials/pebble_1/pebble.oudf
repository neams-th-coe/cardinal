void udfDirichlet(bcData *bc)
{
  if (isField("fluid velocity"))
  {
    bc->uxFluid = 0.0; // x-velocity
    bc->uyFluid = 0.0; // y-velocity
    bc->uzFluid = p_inlet_v; // z-velocity
  }

  if (isField("scalar temperature"))
    bc->sScalar = p_inlet_T; // temperature
}

void udfNeumann(bcData *bc)
{
  // power divided by sphere surface area
  bc->fluxScalar = 315892;
}
